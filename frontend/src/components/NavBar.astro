---
import { getStrapiURL } from '../utils/getStrapi';
import MobileMenu from './MobileMenu';

const { topnav } = Astro.props;
const navigation = topnav.link;
const cta = topnav.button;
const logoLink = topnav.logolink;
const strapiURL = getStrapiURL();
---

<div class='w-full'>
  <!-- Mobile view -->
  <MobileMenu topnav={topnav} client:media='(max-width:50em)' />
  <nav
    class='container relative hidden lg:flex flex-wrap items-center justify-between p-8 mx-auto lg:justify-between xl:px-0'
  >
    <div id='logo'>
      <a href={logoLink.href}>
        <img
          src={logoLink?.image.url?.startsWith('/')
            ? `${strapiURL}${logoLink.image.url}`
            : logoLink?.image?.url}
          alt={logoLink?.image?.alternativeText || 'Logo'}
          class='w-12 lg:w-16 h-auto rounded-full shadow-lg'
        />
      </a>
    </div>
    <!-- Desktop view -->

    <div class='hidden lg:flex lg:items-center text-center'>
      <ul
        class='items-center justify-end flex-1 pt-6 list-none lg:pt-0 lg:flex'
      >
        {
          navigation.map(
            (item: {
              href: string;
              external: boolean;
              text: string;
              children: { link: any[] };
            }) => (
              <li class='relative group'>
                <a
                  href={item.href}
                  target={item.external ? '_blank' : '_self'}
                  class='flex items-center hover:text-red-600 p-2'
                >
                  {item.text}
                  {item.children?.link && (
                    <svg
                      xmlns='http://www.w3.org/2000/svg'
                      fill='none'
                      viewBox='0 0 24 24'
                      stroke-width='3'
                      stroke='currentColor'
                      class='w-3 h-3 ml-1 group-hover:-rotate-90 transition-transform'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        d='M19.5 8.25l-7.5 7.5-7.5-7.5'
                      />
                    </svg>
                  )}
                </a>
                {item.children?.link && (
                  <ul class='absolute hidden group-hover:block bg-white overflow-hidden min-w-max shadow-lg  top-full rounded text-sm'>
                    {item.children.link.map(
                      (subItem: {
                        href: string;
                        external: boolean;
                        text: string;
                      }) => (
                        <li>
                          <a
                            href={subItem.href}
                            target={subItem.external ? '_blank' : '_self'}
                            class='block hover:bg-red-600 gap-y-4 p-2 hover:text-white w-full text-sm text-left'
                          >
                            {subItem.text}
                          </a>
                        </li>
                      )
                    )}
                  </ul>
                )}
              </li>
            )
          )
        }
      </ul>
    </div>
    <div id='cta' class='hidden lg:flex items-center space-x-4'>
      {
        cta.map((item: any) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : '_self'}
            class={
              item.type === 'primary'
                ? 'bg-red-600 hover:bg-red-700 p-2 rounded text-white'
                : 'hover:underline decoration-red-500 decoration-2 underline-offset-2'
            }
          >
            {item.title}
          </a>
        ))
      }
    </div>
  </nav>
  <!-- <pre>{JSON.stringify(topnav,null,2)}</pre> -->
</div>
