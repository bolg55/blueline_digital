---
import { Astronav, MenuItems, MenuIcon } from 'astro-navbar';
import Container from '../container.astro';
import Logo from '../logo.astro';
import Dropdown from './dropdown.astro';

const { topnav } = Astro.props;
const navigation = topnav.link;
const cta = topnav.button;
const logoLink = topnav.logolink;
---

<Container>
  <!-- <Dropdown topnav={topnav} client:load /> -->
  <header class='flex flex-col lg:flex-row justify-between items-center py-3'>
    <Astronav>
      <div class='flex w-full lg:w-auto items-center justify-between'>
        <Logo logoLink={logoLink} />
        <div class='block lg:hidden'>
          <MenuIcon class='w-4 h-4 text-gray-700' />
        </div>
      </div>
      <MenuItems class='hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0'>
        <ul class='flex flex-col lg:flex-row lg:gap-3'>
          {
            navigation.map(
              (item: {
                href: string;
                external: boolean;
                text: string;
                children: { link: any[] };
              }) => (
                <li class='relative group'>
                  <a
                    href={item.href}
                    target={item.external ? '_blank' : '_self'}
                    class='flex items-center hover:text-red-600 p-2'
                  >
                    {item.text}
                    {item.children?.link && (
                      <svg
                        xmlns='http://www.w3.org/2000/svg'
                        fill='none'
                        viewBox='0 0 24 24'
                        stroke-width='3'
                        stroke='currentColor'
                        class='w-3 h-3 ml-1 group-hover:-rotate-90 transition-transform'
                      >
                        <path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          d='M19.5 8.25l-7.5 7.5-7.5-7.5'
                        />
                      </svg>
                    )}
                  </a>
                  {item.children?.link && <Dropdown children={item.children} />}
                </li>
              )
            )
          }
        </ul>
        <div
          id='cta'
          class='flex flex-col lg:flex-row lg:items-center items-start w-full space-x-4'
        >
          {
            cta.map((item: any) => (
              <a
                href={item.href}
                target={item.external ? '_blank' : '_self'}
                class={
                  item.type === 'primary'
                    ? 'lg:bg-red-600 lg:hover:bg-red-700 lg:p-2 lg:rounded lg:text-white'
                    : 'hover:underline decoration-red-500 decoration-2 underline-offset-2'
                }
              >
                {item.title}
              </a>
            ))
          }
        </div>
      </MenuItems>
    </Astronav>
  </header>
</Container>
