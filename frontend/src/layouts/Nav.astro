---
import {
  Astronav,
  Dropdown,
  DropdownItems,
  MenuIcon,
  MenuItems,
} from 'astro-navbar';
import type { NavItem } from '../interfaces/NavItem';

interface Props {
  MainMenuItems: NavItem[];
}

const { MainMenuItems } = Astro.props as Props;
---

<header class='lg:flex p-5 gap-5'>
  <Astronav>
    <div class='flex w-full justify-between'>
      <a>My Logo</a>
      <div class='block lg:hidden'>
        <MenuIcon class='w-6 h-6 text-gray-800' />
      </div>
    </div>
    <MenuItems class='hidden lg:flex'>
      <ul class='flex flex-col lg:flex-row lg:gap-5'>
        {
          MainMenuItems.map((item: NavItem) => (
            <li>
              {item.__component === 'navigation.nav-link' && (
                <a href={item.url}>{item.title}</a>
              )}
              {item.__component === 'navigation.dropdown' && (
                <Dropdown class='group transition-transform ease-in-out'>
                  <button class='flex items-center space-x-1'>
                    <span>{item.title}</span>
                    <svg
                      xmlns='http://www.w3.org/2000/svg'
                      fill='none'
                      viewBox='0 0 24 24'
                      stroke-width='3'
                      stroke='currentColor'
                      class='w-3 h-3 mt-0.5 group-open:-rotate-180 transition-transform'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        d='M19.5 8.25l-7.5 7.5-7.5-7.5'
                      />
                    </svg>
                  </button>
                  <DropdownItems class='relative'>
                    <div class='absolute top-2'>
                      <ul class='shadow rounded text-sm min-w-max'>
                        {item.children?.data.attributes.links.map((link) => (
                          <li>
                            <a
                              href={link.url}
                              class='hover:bg-gray-200 p-2 flex items-center gap-2'
                            >
                              {link?.icon?.data !== null && (
                                <img
                                  src={`${import.meta.env.STRAPI_URL}${
                                    link?.icon?.data?.attributes?.url
                                  }`}
                                  alt={link.title}
                                  class='w-4 h-4 inline-block bg-transparent'
                                />
                              )}
                              {link.title}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </DropdownItems>
                </Dropdown>
              )}
              {item.__component === 'navigation.menu-button' && (
                <a
                  href={item.url}
                  class={`bg-blue-500 hover:bg-blue-600 p-2 rounded ${item.type === 'secondary' ? 'bg-gray-500' : ''}`}
                >
                  {item.title}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </MenuItems>
  </Astronav>
</header>
